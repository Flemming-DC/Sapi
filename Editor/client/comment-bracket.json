{
"comments": {
    "lineComment": "--",
    "blockComment": ["/*", "*/"]
},
"brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
],
"autoClosingPairs": [
    { "open": "{",  "close": "}" },
    { "open": "[",  "close": "]" },
    { "open": "(",  "close": ")" },
    { "open": "'",  "close": "'",  "notIn": ["string", "comment", "String", "Comment"] },
    { "open": "$$", "close": "$$", "notIn": ["string", "comment", "String", "Comment"] },
    { "open": "/*", "close": "*/", "notIn": ["string", "comment", "String", "Comment"] }
],
"surroundingPairs": [
    { "open": "{",  "close": "}"  , "notIn": ["string", "comment", "String", "Comment"] },
    { "open": "[",  "close": "]"  , "notIn": ["string", "comment", "String", "Comment"] },
    { "open": "(",  "close": ")"  , "notIn": ["string", "comment", "String", "Comment"] },
    { "open": "'",  "close": "'"  , "notIn": ["string", "comment", "String", "Comment"] },
    { "open": "$$", "close": "$$" , "notIn": ["string", "comment", "String", "Comment"] }
],
"wordPattern": "\\w+"
}